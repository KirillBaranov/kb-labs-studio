{
  "name": "@kb-labs/studio-plugin-tools",
  "version": "0.1.0",
  "description": "Build tooling for plugin Studio pages — Rspack config for Module Federation remotes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@module-federation/enhanced": "^0.8.0",
    "css-loader": "^7.0.0",
    "style-loader": "^4.0.0"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@rspack/core": "^1.7.0",
    "@types/node": "^24.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
