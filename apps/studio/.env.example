# API Configuration
# All traffic goes through Gateway — auth, namespacing, host dispatch
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Gateway auth token (staticTokens in .kb/kb.config.json → gateway.staticTokens)
VITE_GATEWAY_TOKEN=dev-studio-token

# Data Source Mode
# Options: 'mock' | 'http'
VITE_DATA_SOURCE_MODE=http
